<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="800.0"
            prefWidth="1200.0"
            style="-fx-background-color: #f4f6f8;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1">

    <children>

        <VBox spacing="20.0"
              alignment="TOP_CENTER"
              layoutX="150.0"
              layoutY="30.0"
              prefWidth="900.0">

            <Label text="Asignar Nómina"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

            <HBox spacing="10.0">

                <Label text="Horas:" />

                <TextField fx:id="txtHoras"
                           prefWidth="100.0" />

                <Label text="Horas Extra:" />

                <TextField fx:id="txtHorasExtra"
                           prefWidth="100.0" />

                <Label text="Tarifa:" />

                <TextField fx:id="txtTarifa"
                           prefWidth="100.0" />

                <Button text="Aplicar Cambios"
                        onAction="#On_AplicarCambios"/>

            </HBox>

            <TableView fx:id="tablaNomina"
                       editable="true"
                       prefHeight="500.0"
                       prefWidth="900.0">

                <columns>

                    <TableColumn fx:id="colTrabajador"
                                 text="Trabajador"
                                 prefWidth="180.0"/>

                    <TableColumn fx:id="colRol"
                                 text="Rol"
                                 prefWidth="150.0"/>

                    <TableColumn fx:id="colHoras"
                                 text="Horas"
                                 prefWidth="150.0"/>

                    <TableColumn fx:id="colHorasExtra"
                                 text="Horas Extra"
                                 prefWidth="150.0"/>

                    <TableColumn fx:id="colTarifa"
                                 text="Tarifa"
                                 prefWidth="150.0"/>

                </columns>

            </TableView>

            <HBox spacing="15.0"
                  alignment="CENTER">

                <Button text="Guardar"
                        onAction="#On_Guardar"/>

                <Button text="Volver"
                        onAction="#On_Volver"/>

            </HBox>

        </VBox>

    </children>

</AnchorPane>