<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Separator?>

<AnchorPane xmlns="http://javafx.com/javafx/8.0.171"
            prefWidth="1200"
            prefHeight="720"
            style="-fx-background-color: #f4f6f8;">

    <!-- CONTENEDOR PRINCIPAL -->
    <VBox layoutX="30"
          layoutY="25"
          prefWidth="1140"
          prefHeight="670"
          spacing="25"
          style="-fx-background-color: white;
                 -fx-background-radius: 20;
                 -fx-padding: 30;
                 -fx-border-radius: 20;
                 -fx-border-color: #e5e7eb;">

        <!-- HEADER -->
        <HBox spacing="20">

            <VBox spacing="5" prefWidth="850">

                <Label text="Dashboard Gerencial"
                       style="-fx-font-size: 30px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #111827;" />

                <Label text="Panel de análisis y reportes de conciertos"
                       style="-fx-font-size: 14px;
                              -fx-text-fill: #6b7280;" />

            </VBox>

            <Button text="Exportar Reporte"
                    prefWidth="200"
                    prefHeight="45"
                    style="-fx-background-color: #2563eb;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 12;" />

        </HBox>

        <Separator />

        <!-- TARJETAS KPI -->
        <HBox spacing="20">

            <!-- KPI 1 -->
            <VBox prefWidth="260"
                  prefHeight="130"
                  spacing="12"
                  style="-fx-background-color: #eff6ff;
                         -fx-background-radius: 18;
                         -fx-padding: 20;">

                <Label text="Ingresos Totales"
                       style="-fx-font-size: 15px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #1e3a8a;" />

                <Label text="USD 0.00"
                       style="-fx-font-size: 28px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #2563eb;" />

                <Label text="Último mes"
                       style="-fx-text-fill: #6b7280;" />

            </VBox>

            <!-- KPI 2 -->
            <VBox prefWidth="260"
                  prefHeight="130"
                  spacing="12"
                  style="-fx-background-color: #ecfdf5;
                         -fx-background-radius: 18;
                         -fx-padding: 20;">

                <Label text="Eventos Activos"
                       style="-fx-font-size: 15px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #065f46;" />

                <Label text="0"
                       style="-fx-font-size: 28px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #10b981;" />

                <Label text="Eventos programados"
                       style="-fx-text-fill: #6b7280;" />

            </VBox>

            <!-- KPI 3 -->
            <VBox prefWidth="260"
                  prefHeight="130"
                  spacing="12"
                  style="-fx-background-color: #fffbeb;
                         -fx-background-radius: 18;
                         -fx-padding: 20;">

                <Label text="Artista Más Rentable"
                       style="-fx-font-size: 15px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #92400e;" />

                <Label text="N/A"
                       style="-fx-font-size: 28px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #f59e0b;" />

                <Label text="Mayor rentabilidad"
                       style="-fx-text-fill: #6b7280;" />

            </VBox>

            <!-- KPI 4 -->
            <VBox prefWidth="260"
                  prefHeight="130"
                  spacing="12"
                  style="-fx-background-color: #f5f3ff;
                         -fx-background-radius: 18;
                         -fx-padding: 20;">

                <Label text="Reportes Generados"
                       style="-fx-font-size: 15px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #5b21b6;" />

                <Label text="0"
                       style="-fx-font-size: 28px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #7c3aed;" />

                <Label text="Reportes históricos"
                       style="-fx-text-fill: #6b7280;" />

            </VBox>

        </HBox>

        <Separator />

        <!-- SECCION CENTRAL -->
        <HBox spacing="25">

            <!-- PANEL IZQUIERDO -->
            <VBox prefWidth="420"
                  spacing="18"
                  style="-fx-background-color: #f9fafb;
                         -fx-background-radius: 18;
                         -fx-padding: 22;">

                <Label text="Acciones Principales"
                       style="-fx-font-size: 18px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #111827;" />

                <Button text="Ver Rendimiento de Evento"
                        prefHeight="45"
                        style="-fx-background-color: #2563eb;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 12;" />

                <Button text="Generar Reportes"
                        prefHeight="45"
                        style="-fx-background-color: #10b981;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 12;" />

                <Button text="Consultar Artista Más Rentable"
                        prefHeight="45"
                        style="-fx-background-color: #f59e0b;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 12;" />

                <Button text="Historial de Reportes"
                        prefHeight="45"
                        style="-fx-background-color: #6b7280;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 12;" />

            </VBox>

            <!-- PANEL DERECHO -->
            <VBox prefWidth="650"
                  spacing="18"
                  style="-fx-background-color: #f9fafb;
                         -fx-background-radius: 18;
                         -fx-padding: 22;">

                <Label text="Análisis Rápido"
                       style="-fx-font-size: 18px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #111827;" />

                <VBox spacing="8">

                    <Label text="Seleccionar Evento"
                           style="-fx-font-weight: bold;
                                  -fx-text-fill: #374151;" />

                    <ComboBox prefHeight="40"
                              promptText="Seleccione un evento"
                              style="-fx-background-radius: 10;
                                     -fx-border-radius: 10;" />

                </VBox>

                <VBox spacing="8">

                    <Label text="Resumen del Evento"
                           style="-fx-font-weight: bold;
                                  -fx-text-fill: #374151;" />

                    <TextArea prefHeight="240"
                              wrapText="true"
                              style="-fx-background-radius: 12;
                                     -fx-border-radius: 12;" />

                </VBox>

            </VBox>

        </HBox>

    </VBox>

</AnchorPane>