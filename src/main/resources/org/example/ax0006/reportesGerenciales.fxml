<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="720" prefWidth="1200" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

    <!-- CONTENEDOR PRINCIPAL -->
    <VBox layoutX="30" layoutY="25" prefHeight="670" prefWidth="1140" spacing="25" style="-fx-background-color: white;                  -fx-background-radius: 20;                  -fx-padding: 30;                  -fx-border-radius: 20;                  -fx-border-color: #e5e7eb;">

        <!-- HEADER -->
        <HBox spacing="20">

            <Button fx:id="bt_volver" onAction="#On_volver" prefHeight="45" prefWidth="120" style="-fx-background-color: #ef4444;                -fx-text-fill: white;                -fx-font-weight: bold;                -fx-background-radius: 12;" text="Volver" />
            
            <VBox prefWidth="850" spacing="5">

                <Label style="-fx-font-size: 30px;                               -fx-font-weight: bold;                               -fx-text-fill: #111827;" text="Dashboard Gerencial" />

                <Label style="-fx-font-size: 14px;                               -fx-text-fill: #6b7280;" text="Panel de análisis y reportes de conciertos" />

            </VBox>

            <Button fx:id="bt_exportar" prefHeight="45" prefWidth="200" style="-fx-background-color: #2563eb;                            -fx-text-fill: white;                            -fx-font-size: 14px;                            -fx-font-weight: bold;                            -fx-background-radius: 12;" text="Exportar Reporte" />

        </HBox>

        <Separator />

        <!-- TARJETAS KPI -->
        <HBox spacing="20">

            <!-- KPI 1 -->
            <VBox prefHeight="130" prefWidth="260" spacing="12" style="-fx-background-color: #eff6ff;                          -fx-background-radius: 18;                          -fx-padding: 20;">

                <Label style="-fx-font-size: 15px;                               -fx-font-weight: bold;                               -fx-text-fill: #1e3a8a;" text="Ingresos Totales" />

                <Label fx:id="lbl_ingresosTotales" style="-fx-font-size: 28px;                               -fx-font-weight: bold;                               -fx-text-fill: #2563eb;" text="COP 0.00" />

                <Label style="-fx-text-fill: #6b7280;" text="Último mes" />

            </VBox>

            <!-- KPI 2 -->
            <VBox prefHeight="130" prefWidth="260" spacing="12" style="-fx-background-color: #ecfdf5;                          -fx-background-radius: 18;                          -fx-padding: 20;">

                <Label style="-fx-font-size: 15px;                               -fx-font-weight: bold;                               -fx-text-fill: #065f46;" text="Eventos Activos" />

                <Label fx:id="lbl_eventosActivos" style="-fx-font-size: 28px;                               -fx-font-weight: bold;                               -fx-text-fill: #10b981;" text="0" />

                <Label style="-fx-text-fill: #6b7280;" text="Eventos programados" />

            </VBox>

            <!-- KPI 3 -->
            <VBox prefHeight="130" prefWidth="260" spacing="12" style="-fx-background-color: #fffbeb;                          -fx-background-radius: 18;                          -fx-padding: 20;">

                <Label style="-fx-font-size: 15px;                               -fx-font-weight: bold;                               -fx-text-fill: #92400e;" text="Artista Más Rentable" />

                <Label fx:id="lbl_artistaRentable" style="-fx-font-size: 28px;                               -fx-font-weight: bold;                               -fx-text-fill: #f59e0b;" text="N/A" />

                <Label style="-fx-text-fill: #6b7280;" text="Mayor rentabilidad" />

            </VBox>

            <!-- KPI 4 -->
            <VBox prefHeight="130" prefWidth="260" spacing="12" style="-fx-background-color: #f5f3ff;                          -fx-background-radius: 18;                          -fx-padding: 20;">

                <Label style="-fx-font-size: 15px;                               -fx-font-weight: bold;                               -fx-text-fill: #5b21b6;" text="Reportes Generados" />

                <Label fx:id="lbl_reportesGenerados" style="-fx-font-size: 28px;                               -fx-font-weight: bold;                               -fx-text-fill: #7c3aed;" text="0" />

                <Label style="-fx-text-fill: #6b7280;" text="Reportes históricos" />

            </VBox>

        </HBox>

        <Separator />

        <!-- SECCION CENTRAL -->
        <HBox spacing="25">

            <!-- PANEL IZQUIERDO -->
            <VBox prefWidth="420" spacing="18" style="-fx-background-color: #f9fafb;                          -fx-background-radius: 18;                          -fx-padding: 22;">

                <Label style="-fx-font-size: 18px;                               -fx-font-weight: bold;                               -fx-text-fill: #111827;" text="Acciones Principales" />

                <Button fx:id="bt_rendimiento" prefHeight="45" style="-fx-background-color: #2563eb;                                -fx-text-fill: white;                                -fx-font-weight: bold;                                -fx-background-radius: 12;" text="Ver Rendimiento de Evento" />

                <Button fx:id="bt_generarReporte" prefHeight="45" style="-fx-background-color: #10b981;                                -fx-text-fill: white;                                -fx-font-weight: bold;                                -fx-background-radius: 12;" text="Generar Reportes" />

                <Button fx:id="bt_artistaRentable" prefHeight="45" style="-fx-background-color: #f59e0b;                                -fx-text-fill: white;                                -fx-font-weight: bold;                                -fx-background-radius: 12;" text="Consultar Artista Más Rentable" />

                <Button fx:id="bt_historial" prefHeight="45" style="-fx-background-color: #6b7280;                                -fx-text-fill: white;                                -fx-font-weight: bold;                                -fx-background-radius: 12;" text="Historial de Reportes" />

            </VBox>

            <!-- PANEL DERECHO -->
            <VBox prefWidth="650" spacing="18" style="-fx-background-color: #f9fafb;                          -fx-background-radius: 18;                          -fx-padding: 22;">

                <Label style="-fx-font-size: 18px;                               -fx-font-weight: bold;                               -fx-text-fill: #111827;" text="Análisis Rápido" />

                <VBox spacing="8">

                    <Label style="-fx-font-weight: bold;                                   -fx-text-fill: #374151;" text="Seleccionar Evento" />

                    <ComboBox fx:id="combo_eventos" onAction="#On_seleccionarEvento" prefHeight="40" promptText="Seleccione un evento" style="-fx-background-radius: 10;                                      -fx-border-radius: 10;" />

                </VBox>

                <VBox spacing="8">

                    <Label style="-fx-font-weight: bold;                                   -fx-text-fill: #374151;" text="Resumen del Evento" />

                    <TextArea fx:id="txt_resumenEvento" prefHeight="240" style="-fx-background-radius: 12;                                      -fx-border-radius: 12;" wrapText="true" />

                </VBox>

            </VBox>

        </HBox>

    </VBox>

</AnchorPane>
