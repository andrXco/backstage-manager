<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.pruebafismsd.Controller.SignUpControler">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="475.0" layoutY="220.0" prefHeight="159.0" prefWidth="257.0">
         <children>
            <Label text="Crear Usuario">
               <font>
                  <Font size="20.0" />
               </font>
            </Label>
            <Label text="Usuario:" />
            <TextField fx:id="fid_Usuario" />
            <Label text="Contraseña:" />

            <HBox alignment="CENTER" spacing="5">
               <children>
                  <StackPane prefWidth="200">
                     <children>
                        <PasswordField fx:id="fid_Contrasena" />
                        <TextField fx:id="fid_ContrasenaVisible" managed="false" visible="false" />
                     </children>
                  </StackPane>

                  <Button onAction="#togglePassword" text="👁" />
               </children>
            </HBox>
            <Label text="Confirmar Contraseña:" />
            <HBox alignment="CENTER" spacing="5">
               <children>
                  <StackPane prefWidth="200">
                     <children>
                        <PasswordField fx:id="fid_ContrasenaConfirmation" />
                        <TextField fx:id="fid_ContrasenaVisibleConfirmation" managed="false" visible="false" />
                     </children>
                  </StackPane>
                  <Button onAction="#togglePasswordConfirmation" text="👁" />
               </children>
            </HBox>
         </children>
      </VBox>
      <Button fx:id="fid_sign_up" layoutX="549.0" layoutY="463.0" mnemonicParsing="false" onAction="#On_crear_usuario" text="Crear Usuario" />
      <Button fx:id="fid_login" layoutX="575.0" layoutY="555.0" mnemonicParsing="false" onAction="#On_login" text="Login" />
   </children>
</AnchorPane>
